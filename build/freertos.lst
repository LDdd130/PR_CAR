 170:Core/Src/freertos.c **** /* žł°Ž©ī ToF 1ŪöĆ ŪŹīŽßĀ ‚Üí mm ŽĮłŽü¨/cm hist ÍįĪžč†.
 171:Core/Src/freertos.c ****  * ŽįėŪôėÍįí 3žÉĀ ž≤ėŽ¶¨: 1=žÉą žÉėŪĒĆ(žļ° ŪõĄ ÍłįŽ°Ě), 0=žēĄžßĀ(Ž≤Ąžßď ~33ms vs Ž£®ŪĒĄ ~20ms ‚ÄĒ ž
 172:Core/Src/freertos.c ****  * -1=I2C žóźŽü¨(žóįžÜć SIDE_FAIL_LIMITŪöĆ ‚Üí ŪäłžěĄ ŽßĆŽ£Ć: stale Í∑ľž†ĎÍįížĚī ž°įŪĖ•žĚĄ žė§Žěė Ž
 173:Core/Src/freertos.c ****  * Ž¨īžóźŽü¨ ž†ēž≤ī(TOF_STALE_MS Ž¨īÍįĪžč†)ŽŹĄ ŽßĆŽ£Ć ‚ÄĒ ž£ĹžßÄŽŹĄ žāīžßÄŽŹĄ žēäžĚÄ žĄľžĄúžĚė žėõÍ
 174:Core/Src/freertos.c **** static void tof_record_side(VL53L0X *dev,
 175:Core/Src/freertos.c ****                             uint8_t alive,
 176:Core/Src/freertos.c ****                             uint16_t hist[SIDE_MED_WIN],
 177:Core/Src/freertos.c ****                             uint8_t *miss,
 178:Core/Src/freertos.c ****                             uint32_t *t_fresh,
 179:Core/Src/freertos.c ****                             volatile uint16_t *out_mm,
 180:Core/Src/freertos.c ****                             uint32_t now)
 181:Core/Src/freertos.c **** {
 182:Core/Src/freertos.c ****     if (!alive)
 183:Core/Src/freertos.c ****     {
 184:Core/Src/freertos.c ****         *out_mm = TOF_CAP_MM;
 185:Core/Src/freertos.c ****         for (int i = 0; i < SIDE_MED_WIN; i++) hist[i] = ULTRA_MAX_CM;
 186:Core/Src/freertos.c ****         return;
 187:Core/Src/freertos.c ****     }
 188:Core/Src/freertos.c **** 
 189:Core/Src/freertos.c ****     uint16_t mm;
 190:Core/Src/freertos.c ****     int8_t st = VL53L0X_PollRangeMM(dev, &mm);
