 108:Core/Src/drive.c **** static void Drive_CenteringPD_Run(const DriveInputs *in)
 109:Core/Src/drive.c **** {
 110:Core/Src/drive.c ****     static uint16_t l_buf[CENTER_MA_WIN];
 111:Core/Src/drive.c ****     static uint16_t r_buf[CENTER_MA_WIN];
 112:Core/Src/drive.c ****     static uint8_t  idx = 0U;
 113:Core/Src/drive.c ****     static uint8_t  count = 0U;
 114:Core/Src/drive.c ****     static float    prev_error = 0.0f;
 115:Core/Src/drive.c ****     static uint32_t prev_ms = 0U;
 116:Core/Src/drive.c **** 
 117:Core/Src/drive.c ****     l_buf[idx] = center_sanitize_cm(in->l);
 118:Core/Src/drive.c ****     r_buf[idx] = center_sanitize_cm(in->r);
 119:Core/Src/drive.c **** 
 120:Core/Src/drive.c ****     idx = (uint8_t)((idx + 1U) % CENTER_MA_WIN);
 121:Core/Src/drive.c ****     if (count < CENTER_MA_WIN)
 122:Core/Src/drive.c ****         count++;
 123:Core/Src/drive.c **** 
 124:Core/Src/drive.c ****     float left_cm  = center_avg_u16(l_buf, count);
ARM GAS  C:\Users\user\AppData\Local\Temp\ccncQDtw.s 			page 7


 125:Core/Src/drive.c ****     float right_cm = center_avg_u16(r_buf, count);
 126:Core/Src/drive.c ****     float error = left_cm - right_cm;
 127:Core/Src/drive.c ****     float steer = 0.0f;
 128:Core/Src/drive.c **** 
 129:Core/Src/drive.c ****     if (fabsf(error) <= CENTER_DEADZONE_CM)
 130:Core/Src/drive.c ****     {
 131:Core/Src/drive.c ****         prev_error = 0.0f;
 132:Core/Src/drive.c ****     }
 133:Core/Src/drive.c ****     else
 134:Core/Src/drive.c ****     {
 135:Core/Src/drive.c ****         float dt = 0.02f;
 136:Core/Src/drive.c **** 
 137:Core/Src/drive.c ****         if (prev_ms != 0U && in->now > prev_ms)
 138:Core/Src/drive.c ****         {
 139:Core/Src/drive.c ****             dt = (float)(in->now - prev_ms) / 1000.0f;
 140:Core/Src/drive.c ****             dt = clampf(dt, 0.005f, 0.100f);
 141:Core/Src/drive.c ****         }
 142:Core/Src/drive.c **** 
 143:Core/Src/drive.c ****         float d_error = (error - prev_error) / dt;
 144:Core/Src/drive.c **** 
 145:Core/Src/drive.c ****         steer = (CENTER_KP * error) + (CENTER_KD * d_error);
 146:Core/Src/drive.c ****         steer = clampf(steer, -CENTER_STEER_MAX_PCT, CENTER_STEER_MAX_PCT);
 147:Core/Src/drive.c ****         prev_error = error;
 148:Core/Src/drive.c ****     }
 149:Core/Src/drive.c **** 
 150:Core/Src/drive.c ****     prev_ms = in->now;
 151:Core/Src/drive.c **** 
 152:Core/Src/drive.c ****     float steer_ratio = fabsf(steer) / CENTER_STEER_MAX_PCT;
 153:Core/Src/drive.c ****     float base = CENTER_BASE_SPEED_PCT
 154:Core/Src/drive.c ****                - ((CENTER_BASE_SPEED_PCT - CENTER_MIN_SPEED_PCT) * steer_ratio);
 155:Core/Src/drive.c ****     base = clampf(base, CENTER_MIN_SPEED_PCT, CENTER_BASE_SPEED_PCT);
 156:Core/Src/drive.c **** 
 157:Core/Src/drive.c ****     float lt = clampf(base - steer, 0.0f, 100.0f);
 158:Core/Src/drive.c ****     float rt = clampf(base + steer, 0.0f, 100.0f);
 159:Core/Src/drive.c **** 
 160:Core/Src/drive.c ****     Motor_Left((int8_t)(lt + 0.5f));
 161:Core/Src/drive.c ****     Motor_Right((int8_t)(rt + 0.5f));
 162:Core/Src/drive.c **** 
 163:Core/Src/drive.c ****     dbg_steer      = steer;
 164:Core/Src/drive.c ****     dbg_steer_mode = SM_BOTH;
 165:Core/Src/drive.c ****     dbg_duty_l     = (int16_t)(lt + 0.5f);
 166:Core/Src/drive.c ****     dbg_duty_r     = (int16_t)(rt + 0.5f);
 167:Core/Src/drive.c **** }
