 284:Core/Src/drive.c **** 
 285:Core/Src/drive.c **** static void TurnPid_Run(const DriveInputs *in, float turn_prog)
 286:Core/Src/drive.c **** {
 287:Core/Src/drive.c ****     float dt = 0.02f;
 288:Core/Src/drive.c ****     if (ctx_turn.prev_ms != 0U && in->now > ctx_turn.prev_ms)
 289:Core/Src/drive.c ****         dt = clampf((float)(in->now - ctx_turn.prev_ms) / 1000.0f, 0.005f, 0.100f);
 290:Core/Src/drive.c **** 
 291:Core/Src/drive.c ****     float err = TURN_TARGET_DEG - turn_prog;
 292:Core/Src/drive.c ****     if (err < 0.0f) err = 0.0f;
 293:Core/Src/drive.c **** 
ARM GAS  /tmp/ccEEHtNP.s 			page 14


 294:Core/Src/drive.c ****     if (err < 45.0f)
 295:Core/Src/drive.c ****     {
 296:Core/Src/drive.c ****         ctx_turn.integ += err * dt;
 297:Core/Src/drive.c ****         ctx_turn.integ = clampf(ctx_turn.integ, -TURN_PID_I_MAX, TURN_PID_I_MAX);
 298:Core/Src/drive.c ****     }
 299:Core/Src/drive.c ****     else
 300:Core/Src/drive.c ****     {
 301:Core/Src/drive.c ****         ctx_turn.integ = 0.0f;   /* Ēü░ Ļ░üļÅäņŚÉņä£ļŖö IĒĢŁņØ┤ Ļ│╝ĒÜīņĀä ņŚÉļäłņ¦ĆļĪ£ ņīōņØ┤ņ¦Ć ņĢ
 302:Core/Src/drive.c ****     }
 303:Core/Src/drive.c **** 
 304:Core/Src/drive.c ****     float rate = (ctx_turn.prev_valid) ? (turn_prog - ctx_turn.prev_prog) / dt : 0.0f;
 305:Core/Src/drive.c ****     float cmd = (TURN_PID_KP * err) + (TURN_PID_KI * ctx_turn.integ) - (TURN_PID_KD * rate);
 306:Core/Src/drive.c ****     float min_cmd = (err <= TURN_PID_FINE_DEG) ? (float)TURN_PID_FINE_MIN_PCT : (float)TURN_PID_MIN
 307:Core/Src/drive.c ****     cmd = clampf(cmd, min_cmd, (float)TURN_SPEED);
 308:Core/Src/drive.c **** 
 309:Core/Src/drive.c ****     uint8_t outer = (uint8_t)(cmd + 0.5f);
