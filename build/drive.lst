 148:Core/Src/drive.c ****     }
 149:Core/Src/drive.c ****     else
 150:Core/Src/drive.c ****     {
 151:Core/Src/drive.c ****         float dt = 0.02f;
 152:Core/Src/drive.c **** 
 153:Core/Src/drive.c ****         if (prev_ms != 0U && in->now > prev_ms)
 154:Core/Src/drive.c ****         {
 155:Core/Src/drive.c ****             dt = (float)(in->now - prev_ms) / 1000.0f;
 156:Core/Src/drive.c ****             dt = clampf(dt, 0.005f, 0.100f);
 157:Core/Src/drive.c ****         }
 158:Core/Src/drive.c **** 
